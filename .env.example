# ==========================================
# Edge-AI-Ops-Agent Environment Variables
# ==========================================

# [Core] 大语言模型 API 配置 (必填)
GEMINI_API_KEY=your_gemini_api_key_here

# [Monitor] 边缘节点监听目标配置
MONITOR_TARGET_CONTAINER=wxread-auto
LOCAL_LOG_PATH=/var/log/containers/
POLL_INTERVAL_SECONDS=60

# [Notification] 异常自愈报警推送 (选填)
ALERT_WEBHOOK_URL=https://api.your-domain.com/webhook/alert